/ {
	chosen {
		/delete-property/ zephyr,ipc_shm;
	};
};

&flash0 {
	/delete-node/ partitions;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x0 0xa000>;
		};

		slot0_partition: partition@a000 {
			label = "image-0";
			reg = <0xa000 0xe4000>;
		};

		storage_partition: partition@ee000 {
			label = "storage";
			reg = <0xee000 0x2000>;
		};

		memfault_storage: partition@f0000 {
			label = "memfault-storage";
			reg = <0xf0000 0x10000>;
		};
	};
};

&mx25r64 {
	status = "okay";
	/delete-node/ partitions;

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		slot1_partition: partition@0 {
			label = "image-1";
			reg = <0x0 0xe4000>; /* must match slot0 for MCUBoot swap */
		};

		/* 12 KB dedicated partition for Memfault disconnect-time log-state blob (must fit 16 B hdr + ~80 B context + 8192 B storage) */
		mflt_log_state_partition: partition@e4000 {
			label = "mflt-log-state";
			reg = <0xe4000 0x3000>;
		};

		/* 8 KB dedicated partition for Memfault disconnect-time CDR (WiFi stats) blob */
		mflt_cdr_state_partition: partition@e7000 {
			label = "mflt-cdr-state";
			reg = <0xe7000 0x2000>;
		};
	};
};
