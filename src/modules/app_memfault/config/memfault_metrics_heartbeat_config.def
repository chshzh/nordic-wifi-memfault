/* Application-specific metrics can be defined here.
 * Please refer to https://docs.memfault.com/docs/embedded/metrics-api for more details.
 */

MEMFAULT_METRICS_KEY_DEFINE(switch_1_toggle_count, kMemfaultMetricType_Unsigned)

/* Memfault log ring-buffer fill level at heartbeat boundary (bytes of unsent
 * logs). Correlate with MemfaultSDKMetric_log_dropped_lines to diagnose
 * whether drops coincide with a near-full buffer at trigger time.
 */
MEMFAULT_METRICS_KEY_DEFINE(mflt_log_buf_bytes_used, kMemfaultMetricType_Unsigned)

/* Heap metrics — driven by app_memfault_memonitor_metrics.c via MEMONITOR_CHAN */
#if CONFIG_ZEGO_MEMONITOR && CONFIG_ZEGO_MEMONITOR_HEAP_MONITOR
#if CONFIG_HEAP_MEM_POOL_SIZE > 0
MEMFAULT_METRICS_KEY_DEFINE(ncs_system_heap_total, kMemfaultMetricType_Unsigned)
MEMFAULT_METRICS_KEY_DEFINE(ncs_system_heap_used, kMemfaultMetricType_Unsigned)
MEMFAULT_METRICS_KEY_DEFINE(ncs_system_heap_peak, kMemfaultMetricType_Unsigned)
#endif
#if CONFIG_MBEDTLS_ENABLE_HEAP
MEMFAULT_METRICS_KEY_DEFINE(ncs_mbedtls_heap_total, kMemfaultMetricType_Unsigned)
MEMFAULT_METRICS_KEY_DEFINE(ncs_mbedtls_heap_used, kMemfaultMetricType_Unsigned)
MEMFAULT_METRICS_KEY_DEFINE(ncs_mbedtls_heap_peak, kMemfaultMetricType_Unsigned)
#endif
#endif

